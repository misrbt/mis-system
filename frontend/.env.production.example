# =============================================================================
# PRODUCTION frontend environment template.
#
# Deploy workflow:
#   1. cp .env.production.example .env
#   2. npm run build            # emits dist/ that Nginx serves
# =============================================================================

VITE_API_URL=https://mis.rbtbank.com/api

# Leave VITE_REALTIME_URL UNSET on production. The client connects to the current
# origin and Nginx proxies /socket.io/ to the Node realtime server on 127.0.0.1:6001.

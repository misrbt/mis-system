# =============================================================================
# PRODUCTION environment template.
#
# Deploy workflow:
#   1. cp .env.production.example .env
#   2. Fill the four values marked <FILL IN> below
#   3. php artisan key:generate
#   4. php artisan config:cache
#   5. php artisan migrate --force
#
# Required secrets (everything else is pre-set for production):
#   - DB_PASSWORD                 the production Postgres role password
#   - MAIL_PASSWORD               app-password for mis@rbtbank.com (Microsoft 365)
#   - REALTIME_SECRET             generate with: openssl rand -hex 32
#
# Never commit the populated .env file. Never reuse staging secrets in production.
# =============================================================================

APP_NAME="MIS System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mis.rbtbank.com

SANCTUM_STATEFUL_DOMAINS=mis.rbtbank.com
CORS_ALLOWED_ORIGINS=https://mis.rbtbank.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mis_production
DB_USERNAME=mis_production
DB_PASSWORD=                           # <FILL IN>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Microsoft 365 / Outlook SMTP) ---
# Prerequisites (one-time per mailbox):
#   1. Tenant admin must enable Authenticated SMTP on mis@rbtbank.com:
#        Set-CASMailbox -Identity mis@rbtbank.com -SmtpClientAuthenticationDisabled $false
#   2. If MFA is on the mailbox, generate an App Password — account password won't work.
#   3. Outbound TCP 587 must be open from the production server to smtp.office365.com.
#   4. Recommended: add SPF/DKIM records for rbtbank.com so Gmail/Yahoo recipients
#      don't mark helpdesk approval mail as spam.
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=mis@rbtbank.com
MAIL_PASSWORD=                         # <FILL IN>  app-password for mis@rbtbank.com
MAIL_FROM_ADDRESS=mis@rbtbank.com
MAIL_FROM_NAME="MIS Helpdesk"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Realtime (Socket.io sidecar; Nginx proxies /socket.io/ to 6001) ---
REALTIME_URL=http://127.0.0.1:6001
REALTIME_SECRET=                       # <FILL IN>  openssl rand -hex 32
REALTIME_ENABLED=true

# --- Helpdesk approval workflow (High / Urgent tickets) ---
# Per-branch routing is managed in the admin UI at /helpdesk/approvers
# (table: ticket_approvers). Configure at least one approver per branch
# before the public submit form will accept High/Urgent tickets. If a
# branch has no approver and no parent-branch fallback matches, the public
# submit endpoint will return 422 with a clear message.
# Global approvers (President, C-suite) are notified only via the MIS
# "Forward to President" action on the ticket detail page.
FRONTEND_URL=https://mis.rbtbank.com

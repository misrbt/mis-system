# =============================================================================
# LOCAL DEVELOPMENT environment template.
# For staging/production deployments use the dedicated templates:
#   - .env.staging.example
#   - .env.production.example
# Those files pre-configure SMTP, URLs, and APP_ENV so no hand-editing is
# needed beyond filling a few <FILL IN> secrets.
# =============================================================================

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (helpdesk approval workflow + any future notifications) ---
# Dev can stay on MAIL_MAILER=log to dump outgoing mail to storage/logs/laravel.log.
# Staging and production MUST use smtp with real credentials.
#
# Microsoft 365 / Outlook (RBT Bank mailbox):
#   MAIL_MAILER=smtp
#   MAIL_SCHEME=smtp            # Symfony Mailer accepts "smtp" or "smtps" — NOT "tls".
#                               # Port 587 auto-negotiates STARTTLS with "smtp".
#   MAIL_HOST=smtp.office365.com
#   MAIL_PORT=587
#   MAIL_USERNAME=mis@rbtbank.com
#   MAIL_PASSWORD=<app-password or mailbox password>
#   MAIL_FROM_ADDRESS=mis@rbtbank.com
#   MAIL_FROM_NAME="MIS Helpdesk"
#
# Microsoft 365 prerequisites (one-time per mailbox):
#   1. Tenant admin enables Authenticated SMTP on the mailbox:
#        Set-CASMailbox -Identity mis@rbtbank.com -SmtpClientAuthenticationDisabled $false
#      (or via admin center → Users → Manage email apps → Authenticated SMTP)
#   2. If MFA is on the mailbox, generate an App Password (account password won't work).
#   3. Outbound TCP 587 must be open from the app server to smtp.office365.com.
#   4. Optional but recommended: add SPF/DKIM for rbtbank.com so Gmail/Yahoo
#      don't drop the mail into Spam.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Realtime (Socket.io sidecar) ---
# Laravel POSTs events to this URL. Always localhost because the Node server
# runs on the same machine; Nginx exposes it publicly at /socket.io/.
#   Local:      http://127.0.0.1:6001
#   Staging:    http://127.0.0.1:6001   (frontend reaches it via https://staging.mis.local/socket.io/)
#   Production: http://127.0.0.1:6001   (frontend reaches it via https://mis.rbtbank.com/socket.io/)
REALTIME_URL=http://127.0.0.1:6001
# Must match realtime-server REALTIME_SECRET. Generate: openssl rand -hex 32
REALTIME_SECRET=
# Flip to false to disable realtime emits without redeploy
REALTIME_ENABLED=true

# --- Helpdesk approval workflow (High / Urgent tickets) ---
# When a public submitter picks High or Urgent priority, the ticket is held
# in pending state and an email with Approve / Reject buttons is sent to the
# approver configured for the requester's branch. Per-branch routing is
# managed from the admin UI at /helpdesk/approvers (table: ticket_approvers).
# There is no global env fallback — configure approvers in the admin page.

# Base URL of the FRONTEND. The approval email embeds
# "{FRONTEND_URL}/public-helpdesk/approval/{token}" — if this is wrong, the
# approver's Review button lands on a broken page. Do NOT put the backend URL
# here; this is the React SPA's public base.
#
#   Local:      http://localhost:5173
#   Staging:    https://staging.mis.rbtbank.com
#   Production: https://mis.rbtbank.com
FRONTEND_URL=http://localhost:5173

# --- Queue (optional — speeds up the public submit response in production) ---
# Default QUEUE_CONNECTION=database above runs jobs in-process UNLESS a
# queue worker is running. The approval mail is sent synchronously inside
# PublicTicketController::store; with a fast SMTP this is fine (~1s latency).
# In staging/production, run this under systemd / supervisor so the request
# returns instantly and the email is sent in the background:
#     php artisan queue:work --queue=default --sleep=3 --tries=3
# If no worker is running, leave the ticket send synchronous — it still works.

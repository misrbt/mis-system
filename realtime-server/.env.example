# ---------------------------------------------------------------
# MIS Helpdesk realtime server — example env
# Copy to .env for local dev. See .env.staging.example / .env.production.example
# for non-dev environments.
# ---------------------------------------------------------------
NODE_ENV=development
PORT=6001

# Shared secret — must match backend REALTIME_SECRET
REALTIME_SECRET=dev-secret-change-in-production

# Comma-separated allow-list. "*" is only acceptable in development.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Set to 1 when running behind a reverse proxy (Nginx, etc.)
TRUST_PROXY=0
